# Copy this file to /srv/arcado/.env.prod on the EC2 host and fill in the
# real values. It is read by docker compose via --env-file at deploy time.
# NEVER commit the filled-in version to git.

# ─── Database (RDS) ──────────────────────────────────────────────────────────
# Pull the endpoint from the RDS console. sslmode=require is mandatory on RDS.
DATABASE_URL=postgresql://arcado:REPLACE_ME@arcado-db.xxxxxxxxxxxx.ap-south-1.rds.amazonaws.com:5432/arcado?schema=public&sslmode=require

# ─── Public URLs ─────────────────────────────────────────────────────────────
# NEXT_PUBLIC_* are baked into the Next.js bundle at build time.
NEXT_PUBLIC_API_URL=https://api.arcado.gagankumar.me
NEXT_PUBLIC_WS_URL=wss://api.arcado.gagankumar.me
NEXTAUTH_URL=https://arcado.gagankumar.me
CLIENT_URL=https://arcado.gagankumar.me

# ─── Secrets ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_ME
JWT_SECRET=REPLACE_ME

# ─── OAuth ───────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Admin ───────────────────────────────────────────────────────────────────
ADMIN_EMAILS=you@example.com
